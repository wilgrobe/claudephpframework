APP_NAME="My Application"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_KEY=change-me-to-32-random-characters!!

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=claudephpframework
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_LIFETIME=120

# Dev-only one-click login shortcut on /login. Set to 0 to hide the buttons
# even when APP_ENV is non-production. Forced off in production regardless.
APP_DEV_LOGIN=0

# SECURITY: Trusted reverse proxy
# Only set this if your app runs behind a trusted load balancer or nginx proxy
# that sets X-Forwarded-For. Leave blank for direct connections.
# When set, the leftmost public IP in X-Forwarded-For is used for rate limiting.
# When blank, REMOTE_ADDR is used exclusively (spoofing-safe).
TRUSTED_PROXY=

# Storage paths
STORAGE_PATH=/var/www/storage
LOG_PATH=/var/www/storage/logs

# ── Premium modules ─────────────────────────────────────────────────────────
# Absolute path to the modules/ directory of a paired claudephpframeworkpremium
# checkout. When unset, config/modules.php falls back to the sibling-checkout
# convention (../claudephpframeworkpremium/modules) and silently skips it
# when not present — the framework boots fine on core alone.
#
# Set this in production to point at wherever your deploy puts premium files
# (e.g. /var/app/private-modules), or leave blank for the open-source default.
MODULE_PREMIUM_PATH=


# ══════════════════════════════════════════════════════════════════════════════
# INTEGRATIONS
# ══════════════════════════════════════════════════════════════════════════════
# All external service credentials live here. Each integration follows the
# same pattern:
#
#   1. A provider selector (e.g. MAIL_DRIVER, AI_PROVIDER). Set it to "none"
#      to disable the integration entirely; set it to a provider name (e.g.
#      "openai", "twilio") to activate that provider.
#
#   2. Provider-specific credentials listed beneath the selector. Only the
#      block matching the active provider is consulted at runtime.
#
# See /admin/integrations (superadmin only) for a live status dashboard that
# shows which integrations are currently configured and a Test button to
# verify connections.


# ── Email ─────────────────────────────────────────────────────────────────────
# Drivers: smtp, sendgrid, mailgun, ses, none
# For local dev with smtp4dev: MAIL_DRIVER=smtp, MAIL_HOST=localhost, MAIL_PORT=25,
# and MAIL_ENCRYPTION= (empty). smtp4dev's default listener doesn't speak
# STARTTLS, so leaving MAIL_ENCRYPTION=tls against it causes PHPMailer to
# fail with "STARTTLS command failed: Command unrecognised".
MAIL_DRIVER=smtp

# SMTP (used when MAIL_DRIVER=smtp)
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
# Values: empty (plain), 'tls' (STARTTLS, typical for port 587), 'ssl' (SMTPS,
# typical for port 465). For smtp4dev on port 25 this must be empty.
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=

# From-identity — used by every driver
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="My Application"

# SendGrid API (used when MAIL_DRIVER=sendgrid)
MAIL_SENDGRID_API_KEY=

# Mailgun API (used when MAIL_DRIVER=mailgun)
MAIL_MAILGUN_API_KEY=
MAIL_MAILGUN_DOMAIN=
# Region: "api.mailgun.net" (default, US) or "api.eu.mailgun.net"
MAIL_MAILGUN_ENDPOINT=api.mailgun.net

# Amazon SES (used when MAIL_DRIVER=ses)
MAIL_SES_REGION=us-east-1
MAIL_SES_ACCESS_KEY=
MAIL_SES_SECRET_KEY=


# ── SMS ───────────────────────────────────────────────────────────────────────
# Drivers:
#   auto    — (default) log in dev/local, real provider in production
#   log     — local capture: no network call, rows land in Message Log only
#   none    — disable sending entirely (doSend returns false)
#   twilio  — use Twilio SMS API
#   vonage  — use Vonage (formerly Nexmo) SMS API
#   aws_sns — Amazon SNS (requires the AWS SDK for PHP to actually send)
SMS_DRIVER=auto

# Twilio (used when SMS_DRIVER=twilio)
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_FROM_NUMBER=

# Vonage (used when SMS_DRIVER=vonage)
SMS_VONAGE_API_KEY=
SMS_VONAGE_API_SECRET=
SMS_VONAGE_FROM=

# AWS SNS (used when SMS_DRIVER=aws_sns)
SMS_AWS_REGION=us-east-1
SMS_AWS_ACCESS_KEY=
SMS_AWS_SECRET_KEY=
# Optional: an SNS topic ARN to publish to; if blank, PublishSMS is used per-number.
SMS_AWS_TOPIC_ARN=


# ── Webhooks ──────────────────────────────────────────────────────────────────
# Drivers:
#   auto — (default) log in dev/local, real HTTP in production
#   log  — local capture: no network call, rows land in Message Log only
#   http — actually dispatch via HTTP
#   none — disable outbound webhook sending entirely
WEBHOOK_DRIVER=auto


# ── File Storage ──────────────────────────────────────────────────────────────
# Drivers:
#   local — uploads go to STORAGE_PATH/uploads/ and are served by the app
#   s3    — uploads go to an S3-compatible bucket (AWS S3, MinIO, R2, etc.)
#   gcs   — Google Cloud Storage (requires additional setup, see docs)
STORAGE_DRIVER=local

# S3 (used when STORAGE_DRIVER=s3)
S3_BUCKET=my-bucket
S3_REGION=us-east-1
# Leave S3_ENDPOINT empty for real AWS; set to MinIO / other S3-compatible URL otherwise.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Path-style URLs (bucket.host/key vs bucket-in-hostname): required for MinIO.
S3_USE_PATH_STYLE=0
# Public URL base for rendering stored files. Supports CDN in front of bucket.
S3_PUBLIC_URL=

# Google Cloud Storage (used when STORAGE_DRIVER=gcs)
GCS_BUCKET=
GCS_PROJECT_ID=
# Path to JSON key file OR the JSON content itself. File path is preferred.
GCS_KEY_FILE=


# ── AI ────────────────────────────────────────────────────────────────────────
# Providers: none, openai, anthropic, gemini, bedrock
# Enables AI-powered features (content suggestions, summarization, etc.).
AI_PROVIDER=none

# OpenAI (used when AI_PROVIDER=openai)
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini

# Anthropic (used when AI_PROVIDER=anthropic)
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini (used when AI_PROVIDER=gemini)
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-1.5-flash

# Amazon Bedrock (used when AI_PROVIDER=bedrock)
# Bedrock offers Claude, Llama, Titan, Cohere, and Mistral models through
# one AWS-authenticated endpoint. Requires the AWS SDK for PHP to actually
# invoke; this block just holds the credentials.
AI_BEDROCK_REGION=us-east-1
AI_BEDROCK_ACCESS_KEY=
AI_BEDROCK_SECRET_KEY=
AI_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0


# ── Event Broadcasting ────────────────────────────────────────────────────────
# Providers: none, pusher, ably, soketi
# Pushes real-time events to connected browser clients.
BROADCAST_PROVIDER=none

# Pusher (used when BROADCAST_PROVIDER=pusher)
# Also used for Soketi (self-hosted Pusher-compatible) — set BROADCAST_HOST
# to your Soketi instance's host.
BROADCAST_APP_ID=
BROADCAST_KEY=
BROADCAST_SECRET=
BROADCAST_CLUSTER=mt1
# Defaults: api.pusherapp.com for Pusher; set to your Soketi host otherwise.
BROADCAST_HOST=api.pusherapp.com

# Ably (used when BROADCAST_PROVIDER=ably)
BROADCAST_ABLY_API_KEY=


# ── OAuth / Social Login ──────────────────────────────────────────────────────
# Fill in the CLIENT_ID and CLIENT_SECRET pairs for each provider you want
# to enable. Providers with empty CLIENT_ID are hidden from the login page.
# Callback URLs: <APP_URL>/auth/oauth/<provider>/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=

OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
# Apple requires an additional private key file for client secret signing.
OAUTH_APPLE_KEY_FILE=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=

OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=

OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=


# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Leave SENTRY_DSN blank to disable. A DSN looks like:
#   https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Traces sample rate between 0.0 (disabled) and 1.0 (capture everything).
# Keep low in production to control volume.
SENTRY_TRACES_SAMPLE_RATE=0.0


# ── CAPTCHA / Bot Protection ─────────────────────────────────────────────────
# Providers: none, turnstile (Cloudflare), recaptcha (Google v2), hcaptcha
CAPTCHA_PROVIDER=none
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=


# ── Cache ────────────────────────────────────────────────────────────────────
# Drivers:
#   file      — filesystem cache under STORAGE_PATH/cache/ (default, zero-config)
#   redis     — requires ext-redis and a reachable Redis (or Valkey) server
#   memcached — requires ext-memcached and a reachable Memcached server
CACHE_DRIVER=file

# Redis (used when CACHE_DRIVER=redis).
# Single URL preferred (redis://user:pass@host:port/db) or fall back to
# separate host/port/password/db fields below.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Memcached (used when CACHE_DRIVER=memcached).
# Supports multiple servers; add additional "host:port:weight" entries
# separated by commas in MEMCACHED_SERVERS to pool them.
MEMCACHED_SERVERS=127.0.0.1:11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=


# ── Analytics ────────────────────────────────────────────────────────────────
# Providers: none, plausible, ga, umami
ANALYTICS_PROVIDER=none
# Plausible: your site domain as registered with Plausible
ANALYTICS_PLAUSIBLE_DOMAIN=
# Plausible self-hosted? Override the script host; leave blank for plausible.io.
ANALYTICS_PLAUSIBLE_HOST=
# Google Analytics: measurement ID (G-XXXXXXXXXX)
ANALYTICS_GA_MEASUREMENT_ID=
# Umami: data-website-id + the umami instance URL
ANALYTICS_UMAMI_WEBSITE_ID=
ANALYTICS_UMAMI_HOST=


# ── Payments ─────────────────────────────────────────────────────────────────
# Providers: none, stripe, braintree, square
# Only the active provider's credentials are read at runtime, but you can
# safely leave credentials for multiple providers in place while you
# migrate between them.
PAYMENTS_PROVIDER=none

# Stripe (used when PAYMENTS_PROVIDER=stripe)
# STRIPE_WEBHOOK_SECRET is used to verify incoming webhook signatures.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Braintree / PayPal (used when PAYMENTS_PROVIDER=braintree)
# BRAINTREE_ENVIRONMENT: sandbox or production
BRAINTREE_ENVIRONMENT=sandbox
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

# Square (used when PAYMENTS_PROVIDER=square)
# SQUARE_ENVIRONMENT: sandbox or production
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=


# ── Media CDN / Image Transformation ─────────────────────────────────────────
# Providers: none, cloudinary, imgix, cloudflare
# When set, FileUploadService::url() rewrites image URLs through the CDN
# so you can resize/crop/format-convert on the fly.
MEDIA_CDN_PROVIDER=none
# Cloudinary
MEDIA_CDN_CLOUDINARY_CLOUD_NAME=
MEDIA_CDN_CLOUDINARY_API_KEY=
MEDIA_CDN_CLOUDINARY_API_SECRET=
# imgix
MEDIA_CDN_IMGIX_DOMAIN=
MEDIA_CDN_IMGIX_SIGNING_KEY=
# Cloudflare Images. Delivery URL uses your account's imagedelivery.net hash.
# Either provide an account id + API token for programmatic uploads, OR
# a pre-provisioned delivery hash to rewrite public URLs. Both are shown.
MEDIA_CDN_CLOUDFLARE_ACCOUNT_ID=
MEDIA_CDN_CLOUDFLARE_API_TOKEN=
MEDIA_CDN_CLOUDFLARE_DELIVERY_HASH=


# ── Search ───────────────────────────────────────────────────────────────────
# Providers: none (use MySQL FULLTEXT), meilisearch, algolia, opensearch
SEARCH_PROVIDER=none
# Meilisearch (self-hosted or Meilisearch Cloud)
SEARCH_MEILISEARCH_HOST=http://localhost:7700
SEARCH_MEILISEARCH_API_KEY=
# Algolia
SEARCH_ALGOLIA_APP_ID=
SEARCH_ALGOLIA_API_KEY=
# AWS OpenSearch (or Elasticsearch). Basic auth is used by default; for
# IAM-authenticated domains you'll need to extend SearchService to sign
# requests with AWS Signature v4 (typically via the AWS SDK).
SEARCH_OPENSEARCH_HOST=
SEARCH_OPENSEARCH_USERNAME=
SEARCH_OPENSEARCH_PASSWORD=


# ── Video Hosting ────────────────────────────────────────────────────────────
# Providers: none, mux, cloudflare_stream, vimeo, aws_ivs
# Apps need to wire their own upload / player code against this — the
# framework only manages credentials and signed-URL generation.
VIDEO_PROVIDER=none
# Mux
VIDEO_MUX_TOKEN_ID=
VIDEO_MUX_TOKEN_SECRET=
VIDEO_MUX_SIGNING_KEY_ID=
VIDEO_MUX_SIGNING_KEY=
# Cloudflare Stream
VIDEO_CLOUDFLARE_ACCOUNT_ID=
VIDEO_CLOUDFLARE_API_TOKEN=
# Vimeo (OAuth2 personal access token from developer.vimeo.com)
VIDEO_VIMEO_ACCESS_TOKEN=
# Optional: your Vimeo user id (the numeric one in your vimeo.com/<id> URL)
# for filtering API responses to just your account.
VIDEO_VIMEO_USER_ID=
# AWS IVS (Interactive Video Service). Requires the AWS SDK for PHP for
# stream / channel operations; the framework stores credentials and
# exposes them to app code via VideoService::config().
VIDEO_AWS_REGION=us-east-1
VIDEO_AWS_ACCESS_KEY=
VIDEO_AWS_SECRET_KEY=


# ── Asset URL (CDN for static files) ─────────────────────────────────────────
# When set, all <link>/<script>/asset() URLs are rewritten to start with
# this prefix. Use to serve /assets/css/app.css etc. through Cloudflare,
# BunnyCDN, or any other static CDN in front of your app.
# Leave blank to serve assets from APP_URL (the default).
# Example: https://cdn.example.com
ASSET_URL=


# ── CDN (programmatic cache purge / invalidation) ────────────────────────────
# Distinct from ASSET_URL, which only rewrites public URLs. This section
# wires up the CDN's API so CdnService::purge([...]) can invalidate
# cached paths after a deploy or content update.
#
# Providers: none, cloudflare, cloudfront, fastly, bunny
CDN_PROVIDER=none

# Cloudflare (used when CDN_PROVIDER=cloudflare)
CDN_CLOUDFLARE_ZONE_ID=
CDN_CLOUDFLARE_API_TOKEN=

# AWS CloudFront (used when CDN_PROVIDER=cloudfront)
# Invalidation requires the AWS SDK for PHP; the framework stores creds
# and exposes them via CdnService::config() so your purge action can
# call CreateInvalidation with the right distribution.
CDN_CLOUDFRONT_DISTRIBUTION_ID=
CDN_CLOUDFRONT_AWS_REGION=us-east-1
CDN_CLOUDFRONT_AWS_ACCESS_KEY=
CDN_CLOUDFRONT_AWS_SECRET_KEY=

# Fastly (used when CDN_PROVIDER=fastly)
CDN_FASTLY_SERVICE_ID=
CDN_FASTLY_API_TOKEN=

# BunnyCDN (used when CDN_PROVIDER=bunny)
CDN_BUNNY_PULL_ZONE_ID=
CDN_BUNNY_API_KEY=
