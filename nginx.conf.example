# nginx.conf.example — PHP Framework v2
# Copy to /etc/nginx/sites-available/yoursite and symlink to sites-enabled/

# Rate limiting zones — add to nginx.conf http {} block:
# limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;
# limit_req_zone $binary_remote_addr zone=api:10m   rate=60r/m;

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name yourdomain.com www.yourdomain.com;

    root  /var/www/claudephpframework/public;
    index index.php;

    # ── TLS ────────────────────────────────────────────────────────────────────
    ssl_certificate     /etc/ssl/certs/yourdomain.crt;
    ssl_certificate_key /etc/ssl/private/yourdomain.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_tickets off;

    # ── Security Headers ────────────────────────────────────────────────────────
    add_header X-Content-Type-Options  "nosniff"                          always;
    add_header X-Frame-Options         "SAMEORIGIN"                       always;
    add_header Referrer-Policy         "strict-origin-when-cross-origin"  always;
    add_header Permissions-Policy      "geolocation=(), microphone=(), camera=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # CSP is set dynamically by PHP (public/index.php) — do not duplicate here.
    server_tokens off;

    # ── Block Sensitive Files ───────────────────────────────────────────────────
    location ~* \.(env|log|sql|md|lock|yaml|yml|gitignore|bak|swp)$ {
        deny all; return 404;
    }
    location ~* ^/(app|core|config|database|routes|storage|artisan)(/|$) {
        deny all; return 404;
    }
    location ~* composer\.(json|lock)$ { deny all; return 404; }

    # ── Discovery Files ─────────────────────────────────────────────────────────
    location = /.well-known/security.txt {
        try_files $uri /index.php?$query_string;
    }
    location = /robots.txt  { try_files $uri =404; log_not_found off; access_log off; }
    location = /favicon.ico { try_files $uri =404; log_not_found off; access_log off; }

    # ── Rate Limiting on Auth Endpoints (uncomment after adding zones to nginx.conf)
    # location = /login              { limit_req zone=login burst=5 nodelay; limit_req_status 429; try_files $uri /index.php?$query_string; }
    # location = /auth/2fa/challenge { limit_req zone=login burst=5 nodelay; limit_req_status 429; try_files $uri /index.php?$query_string; }

    # ── Static Assets ────────────────────────────────────────────────────────────
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        add_header X-Content-Type-Options "nosniff" always;
        try_files $uri =404;
        access_log off;
    }

    # ── PHP Routing ──────────────────────────────────────────────────────────────
    location / { try_files $uri $uri/ /index.php?$query_string; }

    location ~ \.php$ {
        try_files $uri =404; # Prevent file type confusion (CVE-2013-4547)
        include       fastcgi_params;
        fastcgi_pass  unix:/run/php/php8.2-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT   $realpath_root;
        fastcgi_hide_header X-Powered-By;
        fastcgi_read_timeout 60;
        fastcgi_buffer_size 128k;
        fastcgi_buffers 4 256k;
    }

    gzip on; gzip_vary on; gzip_min_length 1024; gzip_comp_level 6;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
    client_max_body_size 16M;

    access_log /var/log/nginx/claudephpframework-access.log combined buffer=32k flush=5m;
    error_log  /var/log/nginx/claudephpframework-error.log  warn;
}
