{
    "name": "claudephpframework/v2",
    "description": "Claude PHP MVC Framework v2 — Multi-group, OAuth, Superadmin emulation, Menus, FAQ, Pages, Integrations",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-sodium": "*",
        "dragonmantank/cron-expression": "^3.3",
        "league/flysystem": "3.0",
        "league/flysystem-aws-s3-v3": "3.0",
        "phpmailer/phpmailer": "6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": []
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore",
            "ignore": ["[PKSA-z3gr-8qht-p93v]"]
        }
    }
}
